# ===== 复制这个文件为 .env 并填入你的真实值 =====
# cp .env.example .env   (Windows: copy .env.example .env)

# 服务端口
PORT=3000

# 登录 session 密钥，随便填一串长一点的随机字符
SESSION_SECRET=change-me-to-a-long-random-string

# ===== 登录 =====
# 栖 = 真人，登录用。渡是 AI 伙伴，不登录。
USER_NAME=栖
USER_PASSWORD=set-a-password
# AI 伙伴的名字（粉色气泡 + 聊天里的它）
AI_NAME=渡

# ===== AI 接口 =====
# 选择使用哪家：claude 或 openai
AI_PROVIDER=claude

# --- Claude (Anthropic) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# 如果用国内中转，改成中转地址，否则保持默认
ANTHROPIC_BASE_URL=https://api.anthropic.com

# --- OpenAI / 兼容接口 ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# 用兼容接口（如国内中转）时改这里，例如 https://xxx.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# 渡的人格设定（系统提示词），可自由修改
AI_PERSONA=你是渡，栖的共读伙伴。你温柔、细腻、爱思考，和栖一起读书，真诚回应书里的内容和栖的想法。说话自然、有温度，不啰嗦。

# ===== claude.ai connector（MCP）=====
# 想在 claude.ai 里通过 connector 调用这套书和批注，就填一个 token。
# 填了才会开启 MCP；不填则只有网页 App。
# token 自己生成一串长随机字符（比如 openssl rand -hex 24），别人猜不到即可。
# 在 claude.ai 里添加 custom connector 时，URL 填： https://你的域名/mcp/<这里的token>
MCP_TOKEN=
# 通过 connector（即 claude.ai 里的渡）写的批注算谁名下：Aiden(Aiden/粉) 或 qi(栖/蓝)
MCP_USER_ID=aiden
